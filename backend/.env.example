# MongoDB Connection URI
# Local: mongodb://127.0.0.1:27017/catalyst
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/catalyst
MONGODB_URI=mongodb://127.0.0.1:27017/catalyst

# Server Configuration
NODE_ENV=development
PORT=5000

# JWT Configuration
JWT_SECRET=your_secure_random_jwt_secret_key_change_this_in_production

# Email Configuration (Optional)
# For Gmail, use App Password: https://support.google.com/accounts/answer/185833
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
